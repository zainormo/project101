<!DOCTYPE html>
<html lang="en">
<head>
    <script>
      // Prevent flash of wrong theme
      (function(){
        var t = localStorage.getItem('dms-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DMS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @RenderBody()

    <button id="themeToggle" class="theme-toggle-auth" type="button" aria-label="Toggle theme">
        <i id="themeToggleIcon" class="ri-sun-line"></i>
    </button>

    @await Html.PartialAsync("_Toast")

    <script src="~/js/dms.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>