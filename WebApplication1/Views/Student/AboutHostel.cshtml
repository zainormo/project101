@{ ViewData["Title"] = "About Hostel"; Layout = "~/Views/Shared/_StudentLayout.cshtml"; }

<div class="page-header animate-in"><div><h1 class="page-title">About Hostel</h1><p class="page-subtitle">Rules, contacts & timings</p></div></div>

<div class="card card-premium animate-in" style="margin-bottom:20px;text-align:center;padding:40px;">
    <div style="font-size:48px;margin-bottom:16px;">🏠</div>
    <h2 style="font-size:24px;margin-bottom:8px;">DMS Dormitory</h2>
    <p style="color:var(--text-secondary);">A safe, comfortable, and well-managed home away from home</p>
</div>

<div class="grid-3" style="margin-bottom:24px;">
    <div class="card animate-in">
        <h3 style="font-size:18px;margin-bottom:16px;"><i class="ri-file-list-3-line" style="color:var(--primary-light);margin-right:8px;"></i>Hostel Rules</h3>
        <ol style="padding-left:20px;font-size:14px;color:var(--text-secondary);line-height:2;">
            <li>Maintain silence in corridors after 10 PM</li>
            <li>No unauthorized guests allowed</li>
            <li>Keep rooms clean and tidy at all times</li>
            <li>Report any damages immediately</li>
            <li>No smoking or alcohol on premises</li>
            <li>Respect fellow residents' privacy</li>
            <li>Follow the gate timings strictly</li>
            <li>Attend mandatory hostel meetings</li>
        </ol>
    </div>
    <div class="card animate-in">
        <h3 style="font-size:18px;margin-bottom:16px;"><i class="ri-user-star-line" style="color:var(--accent);margin-right:8px;"></i>Warden Contact</h3>
        <div style="text-align:center;margin-bottom:20px;">
            <div style="width:64px;height:64px;border-radius:16px;background:rgba(6,182,212,0.15);display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 12px;color:var(--accent);"><i class="ri-user-line"></i></div>
            <div style="font-weight:600;font-size:16px;">Mr. Ahmed Raza</div>
            <div style="font-size:13px;color:var(--text-muted);">Chief Warden</div>
        </div>
        <div style="font-size:14px;color:var(--text-secondary);">
            <div style="padding:8px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;"><i class="ri-phone-line" style="color:var(--success);"></i> +92 300 1234567</div>
            <div style="padding:8px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;"><i class="ri-mail-line" style="color:var(--primary-light);"></i> <a href="mailto:warden@dms.edu">warden&#64;dms.edu</a></div>
            <div style="padding:8px 0;display:flex;align-items:center;gap:8px;"><i class="ri-time-line" style="color:var(--warning);"></i> Office: 9 AM – 5 PM</div>
        </div>
    </div>
    <div class="card animate-in">
        <h3 style="font-size:18px;margin-bottom:16px;"><i class="ri-calendar-schedule-line" style="color:var(--warning);margin-right:8px;"></i>Timings</h3>
        <table style="width:100%;font-size:14px;">
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:10px 0;color:var(--text-secondary);">Gate Close</td><td style="padding:10px 0;font-weight:600;text-align:right;">10:00 PM</td></tr>
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:10px 0;color:var(--text-secondary);">Gate Open</td><td style="padding:10px 0;font-weight:600;text-align:right;">6:00 AM</td></tr>
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:10px 0;color:var(--text-secondary);">Breakfast</td><td style="padding:10px 0;font-weight:600;text-align:right;">7:30 – 9:00 AM</td></tr>
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:10px 0;color:var(--text-secondary);">Lunch</td><td style="padding:10px 0;font-weight:600;text-align:right;">12:30 – 2:00 PM</td></tr>
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:10px 0;color:var(--text-secondary);">Dinner</td><td style="padding:10px 0;font-weight:600;text-align:right;">7:30 – 9:00 PM</td></tr>
            <tr><td style="padding:10px 0;color:var(--text-secondary);">Quiet Hours</td><td style="padding:10px 0;font-weight:600;text-align:right;">10 PM – 6 AM</td></tr>
        </table>
    </div>
</div>
